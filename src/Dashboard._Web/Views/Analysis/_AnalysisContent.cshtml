@model Dashboard._Web.ViewModels.Analysis.AnalysisViewModel
@inject IStringLocalizer<SharedResource> SharedLocalizer
@using System.Globalization
@using Dashboard.Application.Helpers

@{
    var today = DateOnly.FromDateTime(DateTime.Today);
    var grouped = Model.AllAnalyses
        .GroupBy(a => a.AnalysisDate.Year)
        .OrderByDescending(g => g.Key)
        .ToList();
}

<!-- Hidden content templates (pre-rendered markdown) -->
@foreach (var analysis in Model.AllAnalyses)
{
    <template id="content-@analysis.RowKey">
        <div class="analysis-content">
            @Html.Raw(MarkdownHelper.ToHtml(analysis.Content))
        </div>
    </template>
}

<div class="card overflow-hidden archive-card">
    <div class="card-body p-0">
        <div class="archive-layout">

            <!-- Left panel -->
            <div class="archive-panel-left">

                <!-- Document browser -->
                <div class="archive-browser">
                    @if (!Model.AllAnalyses.Any())
                    {
                        <p class="text-muted small px-3 py-3">@SharedLocalizer["NoWeeklyAnalyses"]</p>
                    }
                    else
                    {
                        foreach (var yearGroup in grouped)
                        {
                            var yearIsOpen = yearGroup.Key == today.Year;
                            var yearCollapseId = $"year-{yearGroup.Key}";
                            var monthGroups = yearGroup
                                .GroupBy(a => a.AnalysisDate.Month)
                                .OrderByDescending(g => g.Key);

                            <div class="archive-year">
                                <div class="archive-year-header"
                                     data-bs-toggle="collapse"
                                     data-bs-target="#@yearCollapseId"
                                     aria-expanded="@(yearIsOpen ? "true" : "false")">
                                    <i class="fas fa-folder@(yearIsOpen ? "-open" : "") me-2"></i>@yearGroup.Key
                                </div>
                                <div id="@yearCollapseId" class="collapse@(yearIsOpen ? " show" : "")">
                                    @foreach (var monthGroup in monthGroups)
                                    {
                                        var monthIsOpen = monthGroup.Key == today.Month && yearGroup.Key == today.Year;
                                        var monthCollapseId = $"month-{yearGroup.Key}-{monthGroup.Key}";
                                        var monthName = CultureInfo.CurrentUICulture.DateTimeFormat.GetMonthName(monthGroup.Key);
                                        var monthlyReport = monthGroup.FirstOrDefault(a => a.AnalysisType == "monthly");
                                        var weeklyItems = monthGroup.Where(a => a.AnalysisType == "weekly").OrderByDescending(a => a.WeekNumber);

                                        <div class="archive-month">
                                            <div class="archive-month-header"
                                                 data-bs-toggle="collapse"
                                                 data-bs-target="#@monthCollapseId"
                                                 aria-expanded="@(monthIsOpen ? "true" : "false")">
                                                <i class="fas fa-chevron-right archive-month-chevron me-2"></i>@monthName
                                            </div>
                                            <div id="@monthCollapseId" class="collapse@(monthIsOpen ? " show" : "")">
                                                @if (monthlyReport is not null)
                                                {
                                                    <div class="archive-file archive-file--monthly"
                                                         data-analysis-id="@monthlyReport.RowKey"
                                                         onclick="archiveSelectFile(this)">
                                                        <i class="fas fa-star me-2"></i>
                                                        <span class="flex-grow-1">@SharedLocalizer["MonthlyReport"]</span>
                                                        <button class="archive-file-delete" type="button"
                                                                onclick="event.stopPropagation(); archiveDeleteFile('@monthlyReport.RowKey', this)"
                                                                title="@SharedLocalizer["Delete"]">
                                                            <i class="fas fa-trash-alt"></i>
                                                        </button>
                                                    </div>
                                                }
                                                @foreach (var weekly in weeklyItems)
                                                {
                                                    <div class="archive-file archive-file--weekly"
                                                         data-analysis-id="@weekly.RowKey"
                                                         onclick="archiveSelectFile(this)">
                                                        <i class="fas fa-file-alt me-2"></i>
                                                        <span class="flex-grow-1">Week @weekly.WeekNumber</span>
                                                        <span class="archive-file-date">@weekly.AnalysisDate.ToString("MMM d")</span>
                                                        <button class="archive-file-delete" type="button"
                                                                onclick="event.stopPropagation(); archiveDeleteFile('@weekly.RowKey', this)"
                                                                title="@SharedLocalizer["Delete"]">
                                                            <i class="fas fa-trash-alt"></i>
                                                        </button>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    }
                </div>

                <!-- Options footer -->
                <div class="archive-options">
                    <button class="archive-option-btn" type="button" onclick="archiveShowSettings()">
                        <i class="fas fa-sliders-h me-2"></i>@SharedLocalizer["InvestmentSettings"]
                    </button>
                    @if (Model.CanGenerateMonthlyReport)
                    {
                        <button class="archive-option-btn archive-option-btn--primary" id="generateReportBtn" type="button" onclick="archiveGenerateMonthlyReport()">
                            <i class="fas fa-file-alt me-2"></i>@SharedLocalizer["MonthlyReport"]
                        </button>
                    }
                    <button class="archive-option-btn archive-option-btn--subtle" id="runWeeklyBtn" type="button" onclick="archiveRunWeeklyAnalysis()">
                        @SharedLocalizer["RunWeeklyAnalysis"]
                    </button>
                </div>

            </div>

            <!-- Right panel -->
            <div class="archive-panel-right">

                <!-- Empty placeholder -->
                <div id="archivePlaceholder" class="archive-placeholder">
                    <i class="fas fa-file-alt fa-2x text-muted mb-3 d-block"></i>
                    <p class="text-muted mb-0 small">@SharedLocalizer["SelectFileToPreview"]</p>
                </div>

                <!-- Preview content -->
                <div id="archivePreview" class="archive-preview-content d-none">
                    <div id="archiveA4Content"></div>
                </div>

                <!-- Settings form -->
                <div id="archiveSettingsPanel" class="archive-settings-panel d-none">
                    <div class="d-flex align-items-center mb-4">
                        <p class="fw-semibold text-muted text-uppercase mb-0" style="font-size: 0.72rem; letter-spacing: 0.06em;">
                            <i class="fas fa-sliders-h me-2"></i>@SharedLocalizer["InvestmentProfile"]
                        </p>
                    </div>

                    <!-- Risk tolerance -->
                    <div>
                        <label class="form-label fw-semibold">@SharedLocalizer["RiskTolerance"]</label>
                        <div class="btn-group w-100" role="group">
                            <input type="radio" class="btn-check advisor-setting" name="riskTolerance" id="risk-conservative" value="conservative"
                                   @(Model.Settings.RiskTolerance == "conservative" ? "checked" : "") autocomplete="off">
                            <label class="btn btn-outline-primary" for="risk-conservative">Conservative</label>
                            <input type="radio" class="btn-check advisor-setting" name="riskTolerance" id="risk-moderate" value="moderate"
                                   @(Model.Settings.RiskTolerance == "moderate" ? "checked" : "") autocomplete="off">
                            <label class="btn btn-outline-primary" for="risk-moderate">Moderate</label>
                            <input type="radio" class="btn-check advisor-setting" name="riskTolerance" id="risk-aggressive" value="aggressive"
                                   @(Model.Settings.RiskTolerance == "aggressive" ? "checked" : "") autocomplete="off">
                            <label class="btn btn-outline-primary" for="risk-aggressive">Aggressive</label>
                        </div>
                    </div>

                    <hr class="advisor-section-divider">

                    <!-- Investment horizon -->
                    <div>
                        <label class="form-label fw-semibold">@SharedLocalizer["InvestmentHorizon"]</label>
                        <div class="btn-group w-100" role="group">
                            <input type="radio" class="btn-check advisor-setting" name="investmentHorizon" id="horizon-short" value="short"
                                   @(Model.Settings.InvestmentHorizon == "short" ? "checked" : "") autocomplete="off">
                            <label class="btn btn-outline-primary" for="horizon-short">Short (&lt; 3 yr)</label>
                            <input type="radio" class="btn-check advisor-setting" name="investmentHorizon" id="horizon-medium" value="medium"
                                   @(Model.Settings.InvestmentHorizon == "medium" ? "checked" : "") autocomplete="off">
                            <label class="btn btn-outline-primary" for="horizon-medium">Medium (3–10 yr)</label>
                            <input type="radio" class="btn-check advisor-setting" name="investmentHorizon" id="horizon-long" value="long"
                                   @(Model.Settings.InvestmentHorizon == "long" ? "checked" : "") autocomplete="off">
                            <label class="btn btn-outline-primary" for="horizon-long">Long (&gt; 10 yr)</label>
                        </div>
                    </div>

                    <hr class="advisor-section-divider">

                    <!-- Custom instructions -->
                    <div>
                        <label class="form-label fw-semibold" for="customInstructions">@SharedLocalizer["CustomInstructions"]</label>
                        <textarea class="form-control advisor-setting" id="customInstructions" rows="4"
                                  placeholder="e.g. Avoid tobacco stocks. Prefer ETFs.">@Model.Settings.CustomInstructions</textarea>
                    </div>

                    <div class="mt-3">
                        <span id="advisorSavedIndicator" class="advisor-saved-indicator"></span>
                    </div>

                </div>

            </div>

            <!-- Chat panel -->
            <div class="archive-panel-chat">
                <div class="chat-messages" id="chatMessages">
                    <div class="chat-message chat-message--welcome">
                        <p class="mb-0">@SharedLocalizer["ChatWelcome"]</p>
                    </div>
                </div>
                <div class="chat-input-area">
                    <textarea id="chatInput" class="chat-textarea" rows="2"
                              placeholder="@SharedLocalizer["ChatPlaceholder"]"
                              maxlength="2000"></textarea>
                    <button id="chatSendBtn" class="chat-send-btn" type="button" onclick="chatSendMessage()">
                        <i class="fas fa-paper-plane"></i>
                    </button>
                </div>
            </div>

        </div>
    </div>
</div>

<script>
    // --- File selection ---
    function archiveSelectFile(element) {
        const id = element.dataset.analysisId;
        const tmpl = document.getElementById('content-' + id);
        if (!tmpl) return;

        const container = document.getElementById('archiveA4Content');
        container.innerHTML = '';
        container.appendChild(tmpl.content.cloneNode(true));

        archiveShowPreview();
        injectFavicons(container);

        document.querySelectorAll('.archive-file').forEach(f => f.classList.remove('active'));
        element.classList.add('active');
    }

    // --- Panel switching ---
    function archiveShowPreview() {
        document.getElementById('archivePlaceholder').classList.add('d-none');
        document.getElementById('archivePreview').classList.remove('d-none');
        document.getElementById('archiveSettingsPanel').classList.add('d-none');
    }

    function archiveShowSettings() {
        document.getElementById('archivePlaceholder').classList.add('d-none');
        document.getElementById('archivePreview').classList.add('d-none');
        document.getElementById('archiveSettingsPanel').classList.remove('d-none');
        document.querySelectorAll('.archive-file').forEach(f => f.classList.remove('active'));
    }

    function archiveCloseSettings() {
        document.getElementById('archiveSettingsPanel').classList.add('d-none');
        if (document.getElementById('archiveA4Content').hasChildNodes()) {
            document.getElementById('archivePreview').classList.remove('d-none');
        } else {
            document.getElementById('archivePlaceholder').classList.remove('d-none');
        }
    }

    // --- Folder icon animations ---
    document.querySelectorAll('.archive-year-header').forEach(header => {
        const target = document.getElementById(header.getAttribute('data-bs-target').slice(1));
        const icon = header.querySelector('.fas');
        if (!target || !icon) return;
        target.addEventListener('show.bs.collapse', () => { icon.classList.remove('fa-folder'); icon.classList.add('fa-folder-open'); });
        target.addEventListener('hide.bs.collapse', () => { icon.classList.remove('fa-folder-open'); icon.classList.add('fa-folder'); });
    });

    document.querySelectorAll('.archive-month-header').forEach(header => {
        const target = document.getElementById(header.getAttribute('data-bs-target').slice(1));
        const chevron = header.querySelector('.archive-month-chevron');
        if (!target || !chevron) return;
        target.addEventListener('show.bs.collapse', () => chevron.classList.add('rotated'));
        target.addEventListener('hide.bs.collapse', () => chevron.classList.remove('rotated'));
        if (target.classList.contains('show')) chevron.classList.add('rotated');
    });

    // --- Actions ---
    function injectFavicons(root = document) {
        root.querySelectorAll('a[data-favicon]').forEach(link => {
            const img = document.createElement('img');
            img.src = link.getAttribute('data-favicon');
            img.width = 16;
            img.height = 16;
            img.alt = '';
            img.className = 'link-favicon me-1';
            img.onerror = () => img.remove();
            link.prepend(img);
            link.removeAttribute('data-favicon');
        });
    }

    function archiveGenerateMonthlyReport() {
        Swal.fire({
            title: '@SharedLocalizer["ConfirmMonthlyReportTitle"]',
            text: '@SharedLocalizer["ConfirmMonthlyReportText"]',
            icon: 'question',
            showCancelButton: true,
            confirmButtonText: '@SharedLocalizer["Confirm"]',
            cancelButtonText: '@SharedLocalizer["Cancel"]'
        }).then(async (result) => {
            if (!result.isConfirmed) return;

            const btn = document.getElementById('generateReportBtn');
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1" role="status"></span>@SharedLocalizer["GeneratingReport"]';

            try {
                await apiFetch('/analysis/monthly', { method: 'POST', headers: { 'RequestVerificationToken': getAntiForgeryToken() } });
                loadSkeletonSection('/analysis/content');
            } catch {
                showAlert('error', 'Failed to generate monthly report. Please try again.');
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-file-alt me-2"></i>@SharedLocalizer["MonthlyReport"]';
            }
        });
    }

    function archiveRunWeeklyAnalysis() {
        Swal.fire({
            title: '@SharedLocalizer["ConfirmWeeklyAnalysisTitle"]',
            text: '@SharedLocalizer["ConfirmWeeklyAnalysisText"]',
            icon: 'question',
            showCancelButton: true,
            confirmButtonText: '@SharedLocalizer["Confirm"]',
            cancelButtonText: '@SharedLocalizer["Cancel"]'
        }).then(async (result) => {
            if (!result.isConfirmed) return;

            const btn = document.getElementById('runWeeklyBtn');
            btn.disabled = true;
            btn.textContent = '...';

            try {
                await apiFetch('/analysis/run-weekly', { method: 'POST' });
                loadSkeletonSection('/analysis/content');
            } catch {
                showAlert('error', 'Failed to run weekly analysis. Please try again.');
                btn.disabled = false;
                btn.textContent = '@SharedLocalizer["RunWeeklyAnalysis"]';
            }
        });
    }

    function archiveDeleteFile(rowKey, btn) {
        Swal.fire({
            title: '@SharedLocalizer["ConfirmDeleteTitle"]',
            text: '@SharedLocalizer["ConfirmDeleteText"]',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonText: '@SharedLocalizer["Delete"]',
            cancelButtonText: '@SharedLocalizer["Cancel"]',
            confirmButtonColor: '#dc3545'
        }).then(async (result) => {
            if (!result.isConfirmed) return;

            try {
                await apiFetch('/analysis/' + rowKey, { method: 'DELETE' });

                const fileEl = btn.closest('.archive-file');
                const wasActive = fileEl.classList.contains('active');
                const monthDiv = fileEl.closest('.archive-month');
                const archiveYear = monthDiv?.closest('.archive-year');

                fileEl.remove();

                if (monthDiv && !monthDiv.querySelector('.archive-file'))
                    monthDiv.remove();

                if (archiveYear && !archiveYear.querySelector('.archive-month'))
                    archiveYear.remove();

                if (wasActive) {
                    document.getElementById('archiveA4Content').innerHTML = '';
                    document.getElementById('archivePreview').classList.add('d-none');
                    document.getElementById('archivePlaceholder').classList.remove('d-none');
                }

                if (!document.querySelector('.archive-year'))
                    loadSkeletonSection('/analysis/content');
            } catch {
                showAlert('error', 'Failed to delete the analysis. Please try again.');
            }
        });
    }

    function getAntiForgeryToken() {
        const tokenInput = document.querySelector('input[name="__RequestVerificationToken"]');
        return tokenInput ? tokenInput.value : '';
    }

    // --- Chat ---
    function chatSendMessage() {
        const input = document.getElementById('chatInput');
        const message = input.value.trim();
        if (!message) return;
        if (message.length > 2000) return;

        chatAddMessage('user', message);
        input.value = '';
        input.style.height = '';

        const sendBtn = document.getElementById('chatSendBtn');
        sendBtn.disabled = true;

        // Loading bubble
        const loadingId = 'chat-loading-' + Date.now();
        const loadingEl = document.createElement('div');
        loadingEl.className = 'chat-message chat-message--agent chat-message--loading';
        loadingEl.id = loadingId;
        loadingEl.innerHTML = '<span class="spinner-border spinner-border-sm" role="status"></span>';
        document.getElementById('chatMessages').appendChild(loadingEl);
        chatScrollToBottom();

        (async () => {
            try {
                const response = await apiFetch('/analysis/chat', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ message })
                });
                const data = await response.json();
                document.getElementById(loadingId)?.remove();
                chatAddMessage('agent', data.html, true);
            } catch {
                document.getElementById(loadingId)?.remove();
                chatAddMessage('agent', '<p class="text-danger mb-0">@SharedLocalizer["ChatError"]</p>', true);
            } finally {
                sendBtn.disabled = false;
            }
        })();
    }

    function chatAddMessage(role, content, isHtml = false) {
        const container = document.getElementById('chatMessages');
        const el = document.createElement('div');
        el.className = 'chat-message chat-message--' + role;

        if (isHtml) {
            el.innerHTML = content;
            // Inject favicons for any links in agent responses
            injectFavicons(el);
        } else {
            const p = document.createElement('p');
            p.className = 'mb-0';
            p.textContent = content;
            el.appendChild(p);
        }

        container.appendChild(el);
        chatScrollToBottom();
    }

    function chatScrollToBottom() {
        const container = document.getElementById('chatMessages');
        container.scrollTop = container.scrollHeight;
    }

    document.getElementById('chatInput').addEventListener('keydown', function (e) {
        if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            chatSendMessage();
        }
    });

    let advisorSaveDebounce = null;

    function autoSaveAdvisorSettings() {
        const riskTolerance = document.querySelector('input[name="riskTolerance"]:checked')?.value ?? 'moderate';
        const investmentHorizon = document.querySelector('input[name="investmentHorizon"]:checked')?.value ?? 'long';
        const customInstructions = document.getElementById('customInstructions').value.trim();

        (async () => {
            try {
                await apiFetch('/analysis/settings', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ riskTolerance, investmentHorizon, customInstructions })
                });
                showAdvisorSavedIndicator(true);
            } catch {
                showAdvisorSavedIndicator(false);
            }
        })();
    }

    function showAdvisorSavedIndicator(success) {
        const el = document.getElementById('advisorSavedIndicator');
        el.textContent = success ? '@SharedLocalizer["SavedSuccessfully"]' : '@SharedLocalizer["SaveFailed"]';
        el.className = 'advisor-saved-indicator is-visible' + (success ? '' : ' is-error');
        clearTimeout(el._hideTimer);
        el._hideTimer = setTimeout(() => { el.className = 'advisor-saved-indicator'; }, 2000);
    }

    document.querySelectorAll('input[type="radio"].advisor-setting').forEach(el => {
        el.addEventListener('change', autoSaveAdvisorSettings);
    });

    document.getElementById('customInstructions').addEventListener('input', () => {
        clearTimeout(advisorSaveDebounce);
        advisorSaveDebounce = setTimeout(autoSaveAdvisorSettings, 800);
    });
</script>
