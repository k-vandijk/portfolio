@model Dashboard._Web.ViewModels.AnalysisViewModel
@inject IStringLocalizer<SharedResource> SharedLocalizer

<div class="card">
    <div class="card-body">

        <!-- Monthly report (if already generated) -->
        @if (Model.MonthlyReport is not null)
        {
            <div class="card border-0 mb-4 analysis-monthly-card">
                <div class="card-body">
                    <div class="d-flex align-items-center gap-2 mb-3">
                        <i class="fas fa-star u-text-accent-1"></i>
                        <h6 class="mb-0 fw-semibold">@SharedLocalizer["MonthlyReport"] — @Model.MonthlyReport.AnalysisDate.ToString("MMMM yyyy")</h6>
                    </div>
                    <div class="analysis-content">
                        @Html.Raw(MarkdownHelper.ToHtml(Model.MonthlyReport.Content))
                    </div>
                </div>
            </div>
        }

        <!-- Monthly report placeholder (injected via AJAX) -->
        <div id="monthlyReportContainer"></div>

        <!-- Weekly analyses accordion -->
        @if (Model.WeeklyAnalyses.Count > 0)
        {
            <p class="text-muted mb-3 text-uppercase" style="font-size: 0.75rem; letter-spacing: 0.05em;">@SharedLocalizer["WeeklyAnalyses"]</p>
            <div class="accordion" id="weeklyAccordion">
                @for (int i = 0; i < Model.WeeklyAnalyses.Count; i++)
                {
                    var analysis = Model.WeeklyAnalyses[i];
                    var collapseId = $"collapse-{i}";
                    var headingId = $"heading-{i}";

                    <div class="accordion-item border-0 shadow-sm mb-2">
                        <h2 class="accordion-header" id="@headingId">
                            <button class="accordion-button collapsed rounded"
                                    type="button"
                                    data-bs-toggle="collapse"
                                    data-bs-target="#@collapseId"
                                    aria-expanded="false"
                                    aria-controls="@collapseId">
                                <span class="me-3">
                                    <span class="badge bg-primary rounded-pill">Week @analysis.WeekNumber</span>
                                </span>
                                <span class="fw-semibold">@analysis.AnalysisDate.ToString("dddd, MMMM d, yyyy")</span>
                            </button>
                        </h2>
                        <div id="@collapseId"
                             class="accordion-collapse collapse"
                             aria-labelledby="@headingId"
                             data-bs-parent="#weeklyAccordion">
                            <div class="accordion-body">
                                <div class="analysis-content">
                                    @Html.Raw(MarkdownHelper.ToHtml(analysis.Content))
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="fas fa-robot fa-2x text-muted mb-3"></i>
                <p class="text-muted mb-0">@SharedLocalizer["NoWeeklyAnalyses"]</p>
            </div>
        }

    </div>
    <div class="card-footer border-0 bg-transparent pt-0 d-flex align-items-center gap-3 flex-wrap">
        <button class="btn btn-link btn-sm text-muted p-0"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#settingsCollapse"
                aria-expanded="false"
                aria-controls="settingsCollapse">
            <i class="fas fa-sliders-h me-1"></i>@SharedLocalizer["InvestmentSettings"]
        </button>
        @if (Model.CanGenerateMonthlyReport)
        {
            <button class="btn btn-primary btn-sm" id="generateReportBtn" onclick="generateMonthlyReport()">
                <i class="fas fa-file-alt me-1"></i>@SharedLocalizer["MonthlyReport"]
            </button>
        }
        <button class="btn btn-link btn-sm text-muted p-0 ms-auto" id="runWeeklyBtn" onclick="runWeeklyAnalysis()">
            @SharedLocalizer["RunWeeklyAnalysis"]
        </button>
    </div>
</div>

<!-- Investment profile settings (collapsible) -->
<div class="collapse mt-3" id="settingsCollapse">
    <div class="card">
        <div class="card-header">
            <i class="fas fa-sliders-h me-2 text-muted"></i>@SharedLocalizer["InvestmentProfile"]
        </div>
        <div class="card-body">
            <div class="row g-4">

                <!-- Risk tolerance -->
                <div class="col-12 col-md-4">
                    <label class="form-label fw-semibold">@SharedLocalizer["RiskTolerance"]</label>
                    <div class="btn-group w-100" role="group" id="riskToleranceGroup">
                        <input type="radio" class="btn-check" name="riskTolerance" id="risk-conservative" value="conservative"
                               @(Model.Settings.RiskTolerance == "conservative" ? "checked" : "") autocomplete="off">
                        <label class="btn btn-outline-primary" for="risk-conservative">Conservative</label>

                        <input type="radio" class="btn-check" name="riskTolerance" id="risk-moderate" value="moderate"
                               @(Model.Settings.RiskTolerance == "moderate" ? "checked" : "") autocomplete="off">
                        <label class="btn btn-outline-primary" for="risk-moderate">Moderate</label>

                        <input type="radio" class="btn-check" name="riskTolerance" id="risk-aggressive" value="aggressive"
                               @(Model.Settings.RiskTolerance == "aggressive" ? "checked" : "") autocomplete="off">
                        <label class="btn btn-outline-primary" for="risk-aggressive">Aggressive</label>
                    </div>
                </div>

                <!-- Investment horizon -->
                <div class="col-12 col-md-4">
                    <label class="form-label fw-semibold">@SharedLocalizer["InvestmentHorizon"]</label>
                    <div class="btn-group w-100" role="group" id="horizonGroup">
                        <input type="radio" class="btn-check" name="investmentHorizon" id="horizon-short" value="short"
                               @(Model.Settings.InvestmentHorizon == "short" ? "checked" : "") autocomplete="off">
                        <label class="btn btn-outline-primary" for="horizon-short">Short (&lt; 3 yr)</label>

                        <input type="radio" class="btn-check" name="investmentHorizon" id="horizon-medium" value="medium"
                               @(Model.Settings.InvestmentHorizon == "medium" ? "checked" : "") autocomplete="off">
                        <label class="btn btn-outline-primary" for="horizon-medium">Medium (3–10 yr)</label>

                        <input type="radio" class="btn-check" name="investmentHorizon" id="horizon-long" value="long"
                               @(Model.Settings.InvestmentHorizon == "long" ? "checked" : "") autocomplete="off">
                        <label class="btn btn-outline-primary" for="horizon-long">Long (&gt; 10 yr)</label>
                    </div>
                </div>

                <!-- Custom instructions -->
                <div class="col-12 col-md-4">
                    <label class="form-label fw-semibold" for="customInstructions">@SharedLocalizer["CustomInstructions"]</label>
                    <textarea class="form-control" id="customInstructions" rows="3"
                              placeholder="e.g. Avoid tobacco stocks. Prefer ETFs.">@Model.Settings.CustomInstructions</textarea>
                </div>

            </div>

            <div class="d-flex align-items-center gap-3 mt-3">
                <button class="btn btn-primary px-4" id="saveSettingsBtn" onclick="saveSettings()">
                    @SharedLocalizer["Save"]
                </button>
                <span id="saveStatus" class="text-muted small" style="display:none"></span>
            </div>

        </div>
    </div>
</div>

<script>
    function injectFavicons(root = document) {
        root.querySelectorAll('a[data-favicon]').forEach(link => {
            const img = document.createElement('img');
            img.src = link.getAttribute('data-favicon');
            img.width = 16;
            img.height = 16;
            img.alt = '';
            img.className = 'link-favicon me-1';
            img.onerror = () => img.remove();
            link.prepend(img);
            link.removeAttribute('data-favicon');
        });
    }

    function generateMonthlyReport() {
        const btn = document.getElementById('generateReportBtn');
        const container = document.getElementById('monthlyReportContainer');

        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1" role="status"></span>@SharedLocalizer["GeneratingReport"]';

        fetch('/analysis/monthly', { method: 'POST', headers: { 'RequestVerificationToken': getAntiForgeryToken() } })
            .then(response => {
                if (!response.ok) throw new Error('Generation failed');
                return response.text();
            })
            .then(html => {
                container.innerHTML = html;
                btn.style.display = 'none';
                injectFavicons(container);
            })
            .catch(() => {
                showAlert('error', 'Failed to generate monthly report. Please try again.');
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-file-alt me-1"></i>@SharedLocalizer["MonthlyReport"]';
            });
    }

    function runWeeklyAnalysis() {
        const btn = document.getElementById('runWeeklyBtn');
        btn.disabled = true;
        btn.textContent = '...';

        fetch('/analysis/run-weekly', { method: 'POST' })
            .then(response => {
                if (!response.ok) throw new Error('Analysis failed');
                loadSkeletonSection('/analysis/content');
            })
            .catch(() => {
                showAlert('error', 'Failed to run weekly analysis. Please try again.');
                btn.disabled = false;
                btn.textContent = '@SharedLocalizer["RunWeeklyAnalysis"]';
            });
    }

    function getAntiForgeryToken() {
        const tokenInput = document.querySelector('input[name="__RequestVerificationToken"]');
        return tokenInput ? tokenInput.value : '';
    }

    function saveSettings() {
        const btn = document.getElementById('saveSettingsBtn');
        const status = document.getElementById('saveStatus');

        const riskTolerance = document.querySelector('input[name="riskTolerance"]:checked')?.value ?? 'moderate';
        const investmentHorizon = document.querySelector('input[name="investmentHorizon"]:checked')?.value ?? 'long';
        const customInstructions = document.getElementById('customInstructions').value.trim();

        btn.disabled = true;
        btn.textContent = '@SharedLocalizer["Saving"]';
        status.style.display = 'none';

        fetch('/settings/save', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ riskTolerance, investmentHorizon, customInstructions })
        })
        .then(response => {
            if (!response.ok) throw new Error('Save failed');
            status.textContent = '@SharedLocalizer["SavedSuccessfully"]';
            status.className = 'text-success small';
            status.style.display = 'inline';
        })
        .catch(() => {
            status.textContent = '@SharedLocalizer["SaveFailed"]';
            status.className = 'text-danger small';
            status.style.display = 'inline';
        })
        .finally(() => {
            btn.disabled = false;
            btn.textContent = '@SharedLocalizer["Save"]';
        });
    }

    injectFavicons();
</script>
