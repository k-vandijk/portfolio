@inject IStringLocalizer<SharedResource> SharedLocalizer
@{
    ViewData["Title"] = SharedLocalizer["AiAdvisor"];
}

<section id="skeleton-section">
    <div class="card">
        <div class="card-body placeholder-glow">
            <span class="placeholder col-8 mb-2 d-block"></span>
            <span class="placeholder col-6 mb-2 d-block"></span>
            <span class="placeholder col-9 mb-2 d-block"></span>
            <span class="placeholder col-7 mb-2 d-block"></span>
            <span class="placeholder col-8 mb-2 d-block"></span>
            <span class="placeholder col-5 mb-2 d-block"></span>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            loadSkeletonSection('/analysis/content');
        });
    </script>
}
