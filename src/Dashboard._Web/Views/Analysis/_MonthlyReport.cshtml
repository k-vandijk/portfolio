@using Dashboard.Application.Helpers
@model Dashboard._Web.ViewModels.Analysis.AnalysisViewModel

@{
    var monthlyReport = Model.AllAnalyses.FirstOrDefault(a => a.AnalysisType == "monthly");
}

@if (monthlyReport is not null)
{
    <div class="card border-0 shadow-sm mb-4 analysis-monthly-card">
        <div class="card-body">
            <div class="d-flex align-items-center gap-2 mb-3">
                <i class="fas fa-star u-text-accent-1"></i>
                <h6 class="mb-0 fw-semibold">Monthly Report — @monthlyReport.AnalysisDate.ToString("MMMM yyyy")</h6>
            </div>
            <div class="analysis-content">
                @Html.Raw(MarkdownHelper.ToHtml(monthlyReport.Content))
            </div>
        </div>
    </div>
}
