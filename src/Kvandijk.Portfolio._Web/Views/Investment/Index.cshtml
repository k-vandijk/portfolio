@inject IStringLocalizer<SharedResource> SharedLocalizer
@model InvestmentViewModel
@{
    ViewData["Title"] = SharedLocalizer["Investment"];
}

<section id="skeleton-section">
    <div class="row h-47vh">

        <!-- Filters card skeleton (hidden on mobile) -->
        <div class="col-12 col-lg-6 col-xl-6 mb-3 d-none d-md-block">
            <div class="card h-100">
                <div class="card-body placeholder-glow d-flex flex-column justify-content-evenly">
                    <div>
                        <span class="placeholder col-3 mb-2 d-block" style="height:0.65rem"></span>
                        <span class="placeholder col-12 d-block" style="height:2rem;border-radius:var(--border-radius)"></span>
                    </div>
                    <div>
                        <span class="placeholder col-4 mb-2 d-block" style="height:0.65rem"></span>
                        <span class="placeholder col-12 d-block" style="height:2rem;border-radius:var(--border-radius)"></span>
                    </div>
                    <div>
                        <span class="placeholder col-5 mb-2 d-block" style="height:0.65rem"></span>
                        <div class="d-flex gap-2">
                            <span class="placeholder col-2 d-block" style="height:1.75rem;border-radius:var(--border-radius)"></span>
                            <span class="placeholder col-2 d-block" style="height:1.75rem;border-radius:var(--border-radius)"></span>
                            <span class="placeholder col-2 d-block" style="height:1.75rem;border-radius:var(--border-radius)"></span>
                            <span class="placeholder col-2 d-block" style="height:1.75rem;border-radius:var(--border-radius)"></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Pie chart skeleton -->
        <div class="col-12 col-lg-6 col-xl-6 mb-3">
            <partial name="Components/_LineChartSkeleton" model="new LineChartSkeletonViewModel { HeightPixels = 221 }" />
        </div>
    </div>

    <div class="row h-48vh">
        <div class="col-12 col-lg-6 col-xl-6 mb-3">
            <partial name="Components/_LineChartSkeleton" model="new LineChartSkeletonViewModel { HeightPixels = 221 }" />
        </div>
        <div class="col-12 col-lg-6 col-xl-6 mb-3">
            <partial name="Components/_LineChartSkeleton" model="new LineChartSkeletonViewModel { HeightPixels = 221 }" />
        </div>
    </div>
</section>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const url = new URL(window.location.href);
            const tickers = url.searchParams.get('tickers');
            const year = url.searchParams.get('year');

            // Build query string only if params exist
            const params = new URLSearchParams();
            if (tickers) params.set('tickers', tickers);
            if (year) params.set('year', year);

            // Construct the URL dynamically
            const sectionUrl = params.toString()
                ? `/investment/content?${params.toString()}`
                : `/investment/content`;

            loadSkeletonSection(sectionUrl);
        });
    </script>
}
