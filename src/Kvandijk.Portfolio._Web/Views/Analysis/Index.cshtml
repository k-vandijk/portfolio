@inject IStringLocalizer<SharedResource> SharedLocalizer
@{
    ViewData["Title"] = SharedLocalizer["AiAdvisor"];
}

<section id="skeleton-section">
    <div class="card overflow-hidden archive-card placeholder-glow">
        <div class="card-body p-0">
            <div class="archive-layout">

                <!-- Left panel skeleton -->
                <div class="archive-panel-left">
                    <div class="archive-browser px-3 pt-3">
                        <span class="placeholder col-4 mb-3 d-block" style="height:0.65rem"></span>
                        <span class="placeholder col-7 mb-2 d-block" style="height:0.75rem;margin-left:1rem"></span>
                        <span class="placeholder col-6 mb-2 d-block" style="height:0.75rem;margin-left:1rem"></span>
                        <span class="placeholder col-8 mb-2 d-block" style="height:0.75rem;margin-left:1rem"></span>
                        <span class="placeholder col-5 mb-2 d-block" style="height:0.75rem;margin-left:1rem"></span>
                        <span class="placeholder col-4 mt-3 mb-3 d-block" style="height:0.65rem"></span>
                        <span class="placeholder col-6 mb-2 d-block" style="height:0.75rem;margin-left:1rem"></span>
                        <span class="placeholder col-7 mb-2 d-block" style="height:0.75rem;margin-left:1rem"></span>
                        <span class="placeholder col-5 mb-2 d-block" style="height:0.75rem;margin-left:1rem"></span>
                    </div>
                    <div class="archive-options">
                        <span class="placeholder col-8 d-block" style="height:1.75rem;border-radius:var(--border-radius)"></span>
                        <span class="placeholder col-8 d-block" style="height:1.75rem;border-radius:var(--border-radius)"></span>
                    </div>
                </div>

                <!-- Right panel skeleton -->
                <div class="archive-panel-right p-4">
                    <span class="placeholder col-5 mb-4 d-block" style="height:0.85rem"></span>
                    <span class="placeholder col-12 mb-2 d-block"></span>
                    <span class="placeholder col-10 mb-2 d-block"></span>
                    <span class="placeholder col-11 mb-2 d-block"></span>
                    <span class="placeholder col-9 mb-2 d-block"></span>
                    <span class="placeholder col-4 mb-4 d-block" style="height:0.85rem;margin-top:1.5rem"></span>
                    <span class="placeholder col-12 mb-2 d-block"></span>
                    <span class="placeholder col-11 mb-2 d-block"></span>
                    <span class="placeholder col-10 mb-2 d-block"></span>
                    <span class="placeholder col-8 mb-2 d-block"></span>
                    <span class="placeholder col-12 mb-2 d-block"></span>
                </div>

            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            loadSkeletonSection('/analysis/content');
        });
    </script>
}
